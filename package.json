{
  "name": "transport-sv-webapp",
  "private": true,
  "scripts": {
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev:all": "echo 'Chạy riêng từng terminal: pnpm dev:server rồi pnpm dev:client (không chạy song song build/install)'",
    "build:server": "pnpm --filter server build",
    "build:client": "pnpm --filter client build",
    "build": "pnpm run build:server && pnpm run build:client",
    "link-assets": "bash scripts/link-assets.sh",
    "verify:api": "bash scripts/verify-api.sh",
    "test:e2e": "USE_EXISTING_SERVERS=1 playwright test",
    "test:e2e:install": "playwright install chromium",
    "db:migrate": "pnpm --filter server prisma:migrate",
    "db:seed": "pnpm --filter server prisma:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
