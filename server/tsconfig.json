{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmitOnError": true,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "app.ts",
    "lib/**/*.ts",
    "prisma/**/*.ts",
    "config/**/*.ts",
    "routes/**/*.ts",
    "controllers/**/*.ts",
    "services/**/*.ts",
    "models/**/*.ts",
    "middlewares/**/*.ts",
    "validators/**/*.ts",
    "utils/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}

